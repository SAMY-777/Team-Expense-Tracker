# =============================================================================
# server/.env.example
# Copy this file to ".env" in the same folder (server/.env) and fill in real
# values. The ".env" file itself must NEVER be committed to git (see .gitignore).
# =============================================================================

# ---- PostgreSQL connection settings ----------------------------------------
# Host where PostgreSQL is running. "localhost" if you run Postgres on your
# own machine or via the provided docker-compose.yml.
PGHOST=localhost

# Port PostgreSQL is listening on. 5432 is the Postgres default.
PGPORT=5432

# Name of the database this app should use. Must be created before running
# the schema/seed scripts (see README "How to run" section).
PGDATABASE=team_expense_tracker

# Username PostgreSQL should authenticate with.
PGUSER=postgres

# Password for the above user. Change this to whatever you set locally.
PGPASSWORD=postgres

# ---- Server settings ---------------------------------------------------
# Port the Express API server listens on.
PORT=5000

# Comma-separated list of origins allowed to call this API (CORS).
# The React dev server (Vite) runs on 5173 by default.
CLIENT_ORIGIN=http://localhost:5173

# "development" enables verbose error output; "production" hides internals.
NODE_ENV=development
