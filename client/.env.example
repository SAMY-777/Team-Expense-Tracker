# =============================================================================
# client/.env.example
# Copy this file to ".env" in the same folder (client/.env). Vite only
# exposes variables prefixed with VITE_ to browser code, by design (security:
# prevents accidentally shipping server secrets to the client bundle).
# =============================================================================

# Base URL of the backend API this frontend talks to.
# Matches the PORT the server listens on in server/.env.example (5000).
VITE_API_BASE_URL=http://localhost:5000/api
